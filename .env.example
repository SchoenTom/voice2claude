# voice2claude — Konfiguration. Kopiere nach .env und passe an.
# Alle Werte optional; gezeigt sind die Defaults.

# Whisper-Modell: tiny | base | small | medium | large-v3
V2C_MODEL=small

# Injection: auto | paste | tmux | clipboard
#   auto      -> tmux falls Session existiert, sonst paste (Cmd+V ins fokussierte Fenster)
#   paste     -> Cmd+V ins fokussierte Fenster (auf laufende Session aktivierbar)
#   tmux      -> tmux send-keys ins V2C_TMUX-Ziel (auch im Hintergrund)
#   clipboard -> nur kopieren, du fügst selbst ein (keine Berechtigung nötig)
V2C_INJECT=auto
V2C_TMUX=claude

# paste-Backend: Pause (Sek.) zwischen Cmd+V und Enter. Größer = robuster, wenn der
# Prompt schon Inhalt hat (verhindert, dass Enter vor dem Einfügen abschickt).
V2C_SUBMIT_DELAY=0.35

# Sprache erzwingen (de, en, ...). Leer = Auto-Erkennung.
V2C_LANG=de

# Reel/Video → Text (/transcribe-url): Browser-Cookies für Login-gesperrte Reels.
#   safari | chrome | firefox | brave  — leer = nur öffentliche Inhalte.
# V2C_COOKIES=safari

# paste-Modus: bestimmtes Fenster vor dem Einfügen aktivieren (z.B. iTerm). Leer = fokussiert.
# V2C_APP=iTerm

# Port (Browser-HTTPS läuft auf Port+1)
V2C_PORT=8765

# Safety-Guard: 1 = paste tippt NUR in Terminals, sonst Zwischenablage-Fallback
V2C_GUARD=1

# Bestätigungston nach erfolgreichem Einfügen (1/0)
V2C_SOUND=0

# Jargon-Priming: biased die Erkennung Richtung deiner Begriffe
V2C_PROMPT=Claude, Python, git, commit, Funktion, Terminal, Bug, Code, bash, Flask.

# Optionaler Zugriffsschutz: wenn gesetzt, brauchen schreibende Endpoints ?token=…
# Sinnvoll in fremden WLANs (Fernbedienung sendet Tastendrücke!). Leer = aus.
# V2C_TOKEN=einlangesgeheimnis
